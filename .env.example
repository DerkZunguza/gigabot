# ==================== BOT NODE.JS ====================
NODE_ENV=development
PORT=3000
MONGODB_URI=mongodb://mongo:27017/mb_bot

# ==================== MQTT ====================
MQTT_BROKER=mosquitto
MQTT_PORT=1883
MQTT_USERNAME=mqtt_user
MQTT_PASSWORD=mqtt_password_change_this

# ==================== WORKER PYTHON ====================
ARDUINO_SERIAL_PORT=/dev/ttyUSB0
ARDUINO_BAUD_RATE=9600

# ==================== MONGODB ====================
MONGO_USER=admin
MONGO_PASSWORD=admin_change_this

# ==================== ARDUINO ====================
# Configure no arquivo arduino/sim900_mqtt.ino
# MQTT_BROKER="seu-mqtt-broker.com"
# MQTT_USERNAME="mqtt_user"
# MQTT_PASSWORD="mqtt_password"
